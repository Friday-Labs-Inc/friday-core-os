[Unit]
Description=Friday Labs OS — service control agent (Command Center OS control)
Documentation=https://github.com/Friday-Labs-Inc/friday-core-os
After=network-online.target polkit.service
Wants=network-online.target
PartOf=friday-core-os.target

[Service]
Type=simple
User=fridayctl
Group=fridayctl
EnvironmentFile=/etc/friday/os-control.env
ExecStart=/usr/bin/python3 /opt/friday/bin/os-control-agent.py
Restart=on-failure
RestartSec=3
# --- hardening: unprivileged, polkit-scoped, sandboxed ---
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
LogsDirectory=friday-os-control
StateDirectory=friday-brain friday-os
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
LockPersonality=yes

[Install]
WantedBy=friday-core-os.target
